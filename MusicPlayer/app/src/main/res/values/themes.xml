<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.MusicPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
    </style>

    <!-- Splash 启动页主题 -->
    <style name="Theme.MusicPlayer.Splash" parent="Theme.MusicPlayer">
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- 播放器全屏主题 -->
    <style name="Theme.MusicPlayer.Player" parent="Theme.MusicPlayer">
        <item name="android:windowBackground">@color/player_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/player_background</item>
    </style>

    <!-- Chip 标签样式（发现页分类用） -->
    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="chipBackgroundColor">@color/surface</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
